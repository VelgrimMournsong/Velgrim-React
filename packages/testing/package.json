        "react-dom": "19.2.7",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "react": "^18.3.1 || ^19.0.0",
        "react-dom": "^18.3.1 || ^19.0.0"
    },
    "dependencies": {
        "@babel/core": "7.29.7",
        "@babel/plugin-proposal-decorators": "7.29.7",
        "@babel/plugin-transform-runtime": "7.29.7",
        "@babel/preset-env": "7.29.7",
        "@babel/preset-react": "7.29.7",
        "@babel/preset-typescript": "7.29.7",
        "@babel/runtime": "7.29.7",
