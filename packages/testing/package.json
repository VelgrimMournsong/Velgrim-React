        "@jest/types": "30.4.1",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "babel-jest": "30.4.1",
        "cross-env": "10.1.0",
        "jest": "30.4.2",
        "jest-environment-jsdom": "30.4.1",
        "preact": "10.29.2",
        "ts-node": "10.9.2"
    }
